#cloud-config
autoinstall:
  version: 1

  locale: en_GB.UTF-8
  keyboard:
    layout: gb

  network:
    version: 2
    ethernets:
      enp0s3:  # TODO: replace with the correct NIC name
        dhcp4: true

  storage:
    config:
      - type: disk
        id: disk0
        path: /dev/sda  # TODO: adjust to match actual disk
        preserve: false
        ptable: gpt
      - type: partition
        id: part-efi
        device: disk0
        offset: 1048576
        size: 600M
        flag: boot
        grub_device: true
      - type: partition
        id: part-boot
        device: disk0
        size: 1G
      - type: partition
        id: part-swap
        device: disk0
        size: 4G
      - type: partition
        id: part-root
        device: disk0
        size: -1
      - type: format
        id: fmt-efi
        volume: part-efi
        fstype: fat32
      - type: format
        id: fmt-boot
        volume: part-boot
        fstype: ext4
      - type: format
        id: fmt-swap
        volume: part-swap
        fstype: swap
      - type: format
        id: fmt-root
        volume: part-root
        fstype: ext4
      - type: mount
        id: mnt-efi
        device: fmt-efi
        path: /boot/efi
      - type: mount
        id: mnt-boot
        device: fmt-boot
        path: /boot
      - type: mount
        id: mnt-root
        device: fmt-root
        path: /
      - type: mount
        id: mnt-swap
        device: fmt-swap
        path: ""

  identity:
    hostname: sentinel-01
    username: ubuntu
    # TODO: replace with `openssl passwd -6 'your-password'`
    password: "$6$TODO$replace_this_with_real_hash"

  ssh:
    install-server: true
    authorized-keys:
      # TODO: replace with your actual SSH public key
      - "ssh-ed25519 AAAA...TODO... user@host"
    allow-pw: false

  packages:
    - git
    - ansible
    - curl

  late-commands:
    - curtin in-target -- mkdir -p /etc/ansible
    # TODO: replace VAULT_PASSWORD_HERE before writing to USB - never commit the substituted file
    - curtin in-target -- bash -c "echo 'VAULT_PASSWORD_HERE' > /etc/ansible/vault-pass"
    - curtin in-target -- chmod 0600 /etc/ansible/vault-pass
    - curtin in-target -- chown root:root /etc/ansible/vault-pass
    - curtin in-target -- ansible-pull
        -U https://github.com/cbrherms/infra-sentinel.git
        -i ansible/inventory/hosts.yml
        -C main
        --vault-password-file /etc/ansible/vault-pass
        ansible/playbooks/site.yml

  confirm-deprecated-use-of-unencrypted-autoinstall-mode: true
